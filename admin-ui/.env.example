# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# Keycloak OIDC (public values — safe to commit)
KEYCLOAK_ID=admin-ui
KEYCLOAK_SECRET=admin-ui-secret
# Browser-facing issuer (must match the iss claim in tokens).
KEYCLOAK_ISSUER=http://localhost:8090/realms/nexus-gateway
# Internal Docker hostname for server-side OIDC discovery (code exchange, token refresh).
# Uncomment when running inside Docker and the browser-facing URL is unreachable server-side.
# KEYCLOAK_INTERNAL_ISSUER=http://keycloak:8090/realms/nexus-gateway

# Admin API (server-side only — not NEXT_PUBLIC)
ADMIN_API_URL=http://gateway:8080
